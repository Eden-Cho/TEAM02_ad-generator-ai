# OpenAI API 키 (부트캠프 팀 채널에서 받은 키 또는 개인 키)
OPENAI_API_KEY=sk-...

# 사용할 모델 ID — 실제 발급된 키에서 사용 가능한 ID로 조정하세요.
# (부트캠프 가이드 예시: GPT-5.4-mini / gpt-image-1-mini)
# 실제 키가 아직 없으면 gpt-4o-mini / gpt-image-1 등으로 테스트 가능
TEXT_MODEL=gpt-5.4-mini
# 텍스트 LLM 엔드포인트 (비우면 OpenAI / 로컬 Ollama면 http://localhost:11434/v1)
TEXT_BASE_URL=
IMAGE_MODEL=gpt-image-1-mini

# 이미지 크기 (1024x1024 / 1024x1536 세로 / 1536x1024 가로)
IMAGE_SIZE=1024x1024

# === LangFuse 관측 (선택) — 키 없으면 자동 비활성(no-op) ===
# cloud.langfuse.com 무료 프로젝트에서 발급. 있으면 LLM 호출이 자동 추적됨.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# 한글 폰트 경로 — Docker는 fonts-nanum 설치(apt-get install fonts-nanum) 후 아래 경로.
# 비워두면 환경에 맞게 자동 폴백(Docker=Nanum / macOS=AppleSDGothicNeo). 명시하려면 아래 사용.
FONT_PATH=/usr/share/fonts/truetype/nanum/NanumGothic.ttf
# macOS 로컬 실행 시: FONT_PATH=/System/Library/Fonts/AppleSDGothicNeo.ttc

# === 로컬 SDXL 실험 (baseline_02) — 선택 ===
SDXL_BASE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
SDXL_INPAINT_MODEL=diffusers/stable-diffusion-xl-1.0-inpainting-0.1
SDXL_VAE=madebyollin/sdxl-vae-fp16-fix
SDXL_STEPS=30
# MPS는 float16에서 검은 이미지 발생 → float32 권장 (bfloat16으로 속도 실험 가능)
SDXL_DTYPE=float32
